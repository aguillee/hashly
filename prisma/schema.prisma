generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String         @id @default(cuid())
  walletAddress  String         @unique @map("wallet_address")
  points         Int            @default(0)
  loginStreak    Int            @default(0) @map("login_streak")
  lastLogin      DateTime?      @map("last_login")
  isAdmin        Boolean        @default(false) @map("is_admin")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  alias          String?        @map("alias")
  referralCode   String?        @unique @map("referral_code")
  referralPoints Int            @default(0) @map("referral_points")
  referredAt     DateTime?      @map("referred_at")
  events          Event[]
  pointHistory    PointHistory[]
  shares          Share[]
  userMissions    UserMission[]
  votes           Vote[]
  referralsMade   Referral[]     @relation("referralsMade")
  referredBy      Referral?      @relation("referredBy")
  seasonSnapshots SeasonSnapshot[]
  communityProfiles  CommunityProfile[]
  ecosystemProjects  EcosystemProject[]

  @@map("users")
}

model Event {
  id            String        @id @default(cuid())
  title         String
  description   String
  mintDate      DateTime?     @map("mint_date")
  endDate       DateTime?     @map("end_date")
  mintPrice     String        @map("mint_price")
  supply        Int?
  imageUrl      String?       @map("image_url")
  websiteUrl    String?       @map("website_url")
  twitterUrl    String?       @map("twitter_url")
  discordUrl    String?       @map("discord_url")
  category      String?
  status        EventStatus   @default(UPCOMING)
  isApproved    Boolean       @default(false) @map("is_approved")
  votesUp       Int           @default(0) @map("votes_up")
  votesDown     Int           @default(0) @map("votes_down")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdById   String        @map("created_by_id")
  externalId    String?       @map("external_id")
  isForeverMint Boolean       @default(false) @map("is_forever_mint")
  source        DataSource    @default(SENTX)
  custom_links  Json?
  event_type    EventType     @default(MINT_EVENT)
  host          String?
  language      String?
  location      String?
  location_type LocationType?
  prizes        String?
  rejectedAt    DateTime?     @map("rejected_at")
  createdBy     User          @relation(fields: [createdById], references: [id])
  phases        MintPhase[]
  nftVotes      NftVote[]
  shares        Share[]
  votes         Vote[]
  homeAds       HomeAd[]
  checkins      EventCheckin[]

  @@unique([source, externalId])
  @@index([isApproved, isForeverMint])
  @@index([isApproved, status, event_type])
  @@index([isApproved, status, isForeverMint, event_type])
  @@map("events")
}

model MintPhase {
  id           String    @id @default(cuid())
  name         String
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")
  price        String
  maxPerWallet Int?      @map("max_per_wallet")
  supply       Int?
  isWhitelist  Boolean   @default(false) @map("is_whitelist")
  order        Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  eventId      String    @map("event_id")
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("mint_phases")
}

model Vote {
  id        String   @id @default(cuid())
  voteType  VoteType @map("vote_type")
  createdAt DateTime @default(now()) @map("created_at")
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
  @@map("votes")
}

model UserMission {
  id          String    @id @default(cuid())
  progress    Int       @default(0)
  completedAt DateTime? @map("completed_at")
  claimedAt   DateTime? @map("claimed_at")
  resetAt     DateTime? @map("reset_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  userId      String    @map("user_id")
  missionId   String    @map("mission_id")
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, missionId])
  @@map("user_missions")
}

model PointHistory {
  id          String   @id @default(cuid())
  points      Int
  actionType  String   @map("action_type")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])

  @@map("point_history")
}

model Share {
  id        String   @id @default(cuid())
  platform  String   @default("twitter")
  createdAt DateTime @default(now()) @map("created_at")
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId, platform])
  @@map("shares")
}

model NftVote {
  id            String   @id @default(cuid())
  tokenId       String   @map("token_id")
  serialNumber  Int      @map("serial_number")
  walletAddress String   @map("wallet_address")
  voteType      VoteType @map("vote_type")
  voteWeight    Int      @default(1) @map("vote_weight")
  createdAt     DateTime @default(now()) @map("created_at")
  eventId       String   @map("event_id")
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([tokenId, serialNumber, eventId])
  @@map("nft_votes")
}

model Collection {
  id           String           @id @default(cuid())
  tokenAddress String           @unique @map("token_address")
  name         String
  description  String?
  image        String?
  slug         String?
  floor        Int              @default(0)
  volume       Int              @default(0)
  owners       Int              @default(0)
  supply       Int              @default(0)
  totalVotes   Int              @default(0) @map("total_votes")
  sentxStars   Int              @default(0) @map("sentx_stars")
  lastSyncedAt DateTime?        @map("last_synced_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  externalId   String?          @map("external_id")
  source       DataSource       @default(SENTX)
  isApproved   Boolean          @default(false) @map("is_approved")
  isHidden     Boolean          @default(false) @map("is_hidden")
  submittedBy  String?          @map("submitted_by")
  votes        CollectionVote[]

  @@unique([source, externalId])
  @@index([isApproved, isHidden, totalVotes])
  @@map("collections")
}

model CollectionVote {
  id            String     @id @default(cuid())
  walletAddress String     @map("wallet_address")
  voteWeight    Int        @default(1) @map("vote_weight")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  collectionId  String     @map("collection_id")
  nftTokenId    String?    @map("nft_token_id")
  nftSerials    String?    @map("nft_serials")
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([walletAddress, collectionId])
  @@index([collectionId])
  @@index([walletAddress])
  @@map("collection_votes")
}

enum EventStatus {
  UPCOMING
  LIVE
}

enum DataSource {
  SENTX
  KABILA
  DREAMBAY
}

enum VoteType {
  UP
  DOWN
}

enum EventType {
  MINT_EVENT
  ECOSYSTEM_MEETUP
  HACKATHON
}

enum LocationType {
  ONLINE
  IN_PERSON
}

enum HomeAdType {
  EVENT
  CUSTOM
}

model HomeAd {
  id        String     @id @default(cuid())
  type      HomeAdType
  eventId   String?    @map("event_id")
  imageUrl  String?    @map("image_url")
  linkUrl   String?    @map("link_url")
  title     String?
  duration  Int        @default(5)
  order     Int        @default(0)
  isActive  Boolean    @default(true) @map("is_active")
  views     Int        @default(0)
  clicks    Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  event     Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([isActive, order])
  @@map("home_ads")
}

model NewsTracking {
  id        String   @id // RSS article guid
  views     Int      @default(0)
  clicks    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("news_tracking")
}

model Token {
  id           String       @id @default(cuid())
  tokenAddress String       @unique @map("token_address")
  symbol       String
  name         String
  icon         String?
  website      String?
  decimals     Int          @default(8)
  priceUsd     Float?       @map("price_usd")
  marketCap    Float?       @map("market_cap")
  totalVotes   Int          @default(0) @map("total_votes")
  isApproved   Boolean      @default(false) @map("is_approved")
  isHidden     Boolean      @default(false) @map("is_hidden")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  votes        TokenVote[]

  @@index([isApproved, isHidden, totalVotes])
  @@map("tokens")
}

model TokenVote {
  id            String   @id @default(cuid())
  walletAddress String   @map("wallet_address")
  voteWeight    Int      @default(1) @map("vote_weight")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  tokenId       String   @map("token_id")
  nftTokenId    String?  @map("nft_token_id")
  nftSerials    String?  @map("nft_serials")
  token         Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([walletAddress, tokenId])
  @@index([tokenId])
  @@index([walletAddress])
  @@map("token_votes")
}

// Daily vote limit tracking (5 votes per wallet per day)
model DailyVoteLimit {
  id            String   @id @default(cuid())
  walletAddress String   @map("wallet_address")
  date          String   // "2024-02-13" (UTC date)
  voteCount     Int      @default(0) @map("vote_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([walletAddress, date])
  @@index([walletAddress])
  @@map("daily_vote_limits")
}

// Event check-in (proof of attendance)
model EventCheckin {
  id            String   @id @default(cuid())
  eventId       String   @map("event_id")
  walletAddress String   @map("wallet_address")
  hcsMessageId  String?  @map("hcs_message_id")
  createdAt     DateTime @default(now()) @map("created_at")
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, walletAddress])
  @@index([eventId])
  @@index([walletAddress])
  @@map("event_checkins")
}

// Host request for Attendance Badge
model HostRequest {
  id            String            @id @default(cuid())
  walletAddress String            @map("wallet_address")
  eventId       String            @map("event_id")
  status        HostRequestStatus @default(PENDING)
  message       String?           // Optional message from requester
  rejectedReason String?          @map("rejected_reason")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  reviewedAt    DateTime?         @map("reviewed_at")
  reviewedBy    String?           @map("reviewed_by") // Admin wallet

  @@unique([walletAddress, eventId])
  @@index([status])
  @@index([eventId])
  @@map("host_requests")
}

enum HostRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Attendance Badge configuration for an event
model AttendanceBadge {
  id          String              @id @default(cuid())
  eventId     String              @unique @map("event_id")
  hostWallet  String              @map("host_wallet")
  tokenId     String?             @map("token_id") // Hedera NFT Token ID
  name        String
  description String?
  imageUrl        String?             @map("image_url")
  imageCid        String?             @map("image_cid") // IPFS CID (legacy)
  metadataCid     String?             @map("metadata_cid") // IPFS CID (legacy)
  imageTopicId    String?             @map("image_topic_id") // HCS-1 topic for image
  metadataTopicId String?             @map("metadata_topic_id") // HCS-1 topic for metadata
  imageInscriptionTxId    String?     @map("image_inscription_tx_id") // Pending Kiloscribe tx ID for image
  metadataInscriptionTxId String?     @map("metadata_inscription_tx_id") // Pending Kiloscribe tx ID for metadata
  status          AttendanceBadgeStatus @default(DRAFT)
  supply          Int                 @default(0) // Number minted
  airdropAttempts Int                 @default(0) @map("airdrop_attempts")
  airdropDeadline DateTime?           @map("airdrop_deadline")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  mintedAt        DateTime?           @map("minted_at")
  claims          BadgeClaim[]

  @@index([hostWallet])
  @@index([status])
  @@map("attendance_badges")
}

enum AttendanceBadgeStatus {
  DRAFT       // Badge created but token not yet created on Hedera
  TOKEN_CREATED // Token ID created on Hedera, ready to mint
  MINTED      // NFTs minted to host wallet
  DISTRIBUTED // Airdrops sent to attendees
  EXPIRED     // Deadline passed or 3 attempts exhausted
}

// Individual badge claims (airdrops sent)
model BadgeClaim {
  id            String          @id @default(cuid())
  badgeId       String          @map("badge_id")
  walletAddress String          @map("wallet_address")
  serialNumber  Int             @map("serial_number")
  txId          String?         @map("tx_id") // Airdrop transaction ID
  status        BadgeClaimStatus @default(PENDING)
  errorReason   String?         @map("error_reason")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  badge         AttendanceBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([badgeId, walletAddress])
  @@unique([badgeId, serialNumber])
  @@index([walletAddress])
  @@map("badge_claims")
}

enum BadgeClaimStatus {
  PENDING   // Queued for airdrop
  SENT      // Airdrop sent
  CLAIMED   // User accepted airdrop
  FAILED    // Airdrop failed
}

// Community profiles (HashWorld globe)
enum CommunityProfileType {
  USER
  BUILDER
  PERSON
  PROJECT
}

model CommunityProfile {
  id            String               @id @default(cuid())
  userId        String               @map("user_id")
  type          CommunityProfileType @default(USER)
  displayName   String               @map("display_name")
  twitterHandle String?              @map("twitter_handle")
  countryCode   String               @map("country_code")
  bio           String?
  avatarUrl     String?              @map("avatar_url")
  isVisible     Boolean              @default(true) @map("is_visible")
  isApproved    Boolean              @default(false) @map("is_approved")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ecosystemProject EcosystemProject?

  @@index([userId])
  @@index([countryCode])
  @@index([isVisible, isApproved])
  @@map("community_profiles")
}

// Ecosystem projects
enum EcosystemCategory {
  DEFI
  TOOLS
  MARKETPLACE
  DATA
  COMMUNITY
  WALLET
  BRIDGE
  GAMING
  NFT
  EDUCATION
  INFRASTRUCTURE
  OTHER
}

model EcosystemProject {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  categories         EcosystemCategory[]
  countryCode        String             @map("country_code")
  logoUrl            String             @map("logo_url")
  description        String
  websiteUrl         String             @map("website_url")
  twitterUrl         String?            @map("twitter_url")
  discordUrl         String?            @map("discord_url")
  telegramUrl        String?            @map("telegram_url")
  linkedinUrl        String?            @map("linkedin_url")
  contactEmail       String?            @map("contact_email")
  isApproved         Boolean            @default(false) @map("is_approved")
  isVisible          Boolean            @default(true) @map("is_visible")
  submittedById      String             @map("submitted_by_id")
  communityProfileId String?            @unique @map("community_profile_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  totalVotes         Int                @default(0) @map("total_votes")

  submittedBy        User               @relation(fields: [submittedById], references: [id])
  communityProfile   CommunityProfile?  @relation(fields: [communityProfileId], references: [id])
  votes              EcosystemProjectVote[]

  @@index([isApproved, isVisible])
  @@index([categories])
  @@index([submittedById])
  @@map("ecosystem_projects")
}

model EcosystemProjectVote {
  id            String           @id @default(cuid())
  walletAddress String           @map("wallet_address")
  voteType      String           @default("UP") @map("vote_type")
  voteWeight    Int              @default(1) @map("vote_weight")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  projectId     String           @map("project_id")
  nftTokenId    String?          @map("nft_token_id")
  nftSerials    String?          @map("nft_serials")
  project       EcosystemProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([walletAddress, projectId])
  @@index([projectId])
  @@index([walletAddress])
  @@map("ecosystem_project_votes")
}

// Referral system
model Referral {
  id                String            @id @default(cuid())
  referrerId        String            @map("referrer_id")
  refereeId         String            @unique @map("referee_id")
  referrerBonusPaid        Boolean  @default(false) @map("referrer_bonus_paid")
  referrerBonusSeasonNumber Int?    @map("referrer_bonus_season_number")
  createdAt                DateTime @default(now()) @map("created_at")
  referrer          User              @relation("referralsMade", fields: [referrerId], references: [id])
  referee           User              @relation("referredBy", fields: [refereeId], references: [id])
  earnings          ReferralEarning[]

  @@index([referrerId])
  @@map("referrals")
}

model ReferralEarning {
  id         String   @id @default(cuid())
  referralId String   @map("referral_id")
  points     Int
  sourceType String   @map("source_type") // SIGNUP_BONUS | REFERRER_BONUS | COMMISSION
  description String?
  createdAt  DateTime @default(now()) @map("created_at")
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@index([referralId])
  @@map("referral_earnings")
}

// Seasons (monthly)
model Season {
  id        String           @id @default(cuid())
  number    Int              @unique
  startDate DateTime         @map("start_date")
  endDate   DateTime         @map("end_date")
  createdAt DateTime         @default(now()) @map("created_at")
  snapshots SeasonSnapshot[]

  @@map("seasons")
}

model SeasonSnapshot {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  seasonId       String   @map("season_id")
  missionPoints  Int      @map("mission_points")
  badgePoints    Int      @map("badge_points")
  referralPoints Int      @map("referral_points")
  totalPoints    Int      @map("total_points")
  rank           Int?
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id])
  season         Season   @relation(fields: [seasonId], references: [id])

  @@unique([userId, seasonId])
  @@index([seasonId, totalPoints(sort: Desc)])
  @@map("season_snapshots")
}

